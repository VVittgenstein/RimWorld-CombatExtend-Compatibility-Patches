<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Combat Extended</li>
            <li>Landkreuzer P1000 Ratte</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>

                <!-- ==================== -->
                <!-- P1000_MainTurret: 280mm main cannon → AmmoSet_28cmSpgrShell -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MainTurret"]/projectile</xpath>
                    <value>
                        <projectile>Bullet_28cmSpgrShell_HE</projectile>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MainTurret"]/reloadTimer</xpath>
                    <value>
                        <reloadTimer>16.0</reloadTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MainTurret"]/warmUpTimer</xpath>
                    <value>
                        <warmUpTimer>5.5</warmUpTimer>
                    </value>
                </li>

                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MainTurret"]</xpath>
                    <value>
                        <li Class="Vehicles.CETurretDataDefModExtension">
                            <ammoSet>AmmoSet_28cmSpgrShell</ammoSet>
                            <shotHeight>3.5</shotHeight>
                            <sway>0.82</sway>
                            <spread>0.01</spread>
                        </li>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_MausTurret: 75mm Maus cannon → AmmoSet_75x350mmR -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausTurret"]/projectile</xpath>
                    <value>
                        <projectile>Bullet_75x350mmR_HE</projectile>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausTurret"]/reloadTimer</xpath>
                    <value>
                        <reloadTimer>6.2</reloadTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausTurret"]/warmUpTimer</xpath>
                    <value>
                        <warmUpTimer>2.8</warmUpTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausTurret"]/maxRange</xpath>
                    <value>
                        <maxRange>86</maxRange>
                    </value>
                </li>

                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausTurret"]</xpath>
                    <value>
                        <li Class="Vehicles.CETurretDataDefModExtension">
                            <ammoSet>AmmoSet_75x350mmR</ammoSet>
                            <shotHeight>2.5</shotHeight>
                            <speed>124</speed>
                            <sway>0.82</sway>
                            <spread>0.01</spread>
                        </li>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_MausFTTurret: 75mm front cannon → AmmoSet_75x350mmR -->
                <!-- shotHeight=1.8 (lower hull mount vs 2.5 for side Maus turrets) -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausFTTurret"]/projectile</xpath>
                    <value>
                        <projectile>Bullet_75x350mmR_HE</projectile>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausFTTurret"]/reloadTimer</xpath>
                    <value>
                        <reloadTimer>6.2</reloadTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausFTTurret"]/warmUpTimer</xpath>
                    <value>
                        <warmUpTimer>2.8</warmUpTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausFTTurret"]/maxRange</xpath>
                    <value>
                        <maxRange>86</maxRange>
                    </value>
                </li>

                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_MausFTTurret"]</xpath>
                    <value>
                        <li Class="Vehicles.CETurretDataDefModExtension">
                            <ammoSet>AmmoSet_75x350mmR</ammoSet>
                            <shotHeight>1.8</shotHeight>
                            <speed>124</speed>
                            <sway>0.82</sway>
                            <spread>0.01</spread>
                        </li>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_FlakTurret: 20mm Oerlikon AA → AmmoSet_20x128mmOerlikon -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/projectile</xpath>
                    <value>
                        <projectile>Bullet_20x128mmOerlikon_HE</projectile>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/reloadTimer</xpath>
                    <value>
                        <reloadTimer>7.8</reloadTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/warmUpTimer</xpath>
                    <value>
                        <warmUpTimer>2.3</warmUpTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/magazineCapacity</xpath>
                    <value>
                        <magazineCapacity>60</magazineCapacity>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/maxRange</xpath>
                    <value>
                        <maxRange>78</maxRange>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]/fireModes</xpath>
                    <value>
                        <fireModes>
                            <li>
                                <shotsPerBurst>1</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Single</label>
                                <texPath>UI/Gizmos/FireRate_Single</texPath>
                            </li>
                            <li>
                                <shotsPerBurst>3</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Burst</label>
                                <texPath>UI/Gizmos/FireRate_Burst</texPath>
                            </li>
                            <li>
                                <shotsPerBurst>8</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Auto</label>
                                <texPath>UI/Gizmos/FireRate_Auto</texPath>
                            </li>
                        </fireModes>
                    </value>
                </li>

                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_FlakTurret"]</xpath>
                    <value>
                        <li Class="Vehicles.CETurretDataDefModExtension">
                            <ammoSet>AmmoSet_20x128mmOerlikon</ammoSet>
                            <shotHeight>2.0</shotHeight>
                            <speed>183</speed>
                            <sway>1.61</sway>
                            <spread>0.01</spread>
                        </li>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_Ball_Turret: 7.62mm MG → AmmoSet_762x51mmNATO -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/projectile</xpath>
                    <value>
                        <projectile>Bullet_762x51mmNATO_FMJ</projectile>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/reloadTimer</xpath>
                    <value>
                        <reloadTimer>7.8</reloadTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/warmUpTimer</xpath>
                    <value>
                        <warmUpTimer>1.3</warmUpTimer>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/magazineCapacity</xpath>
                    <value>
                        <magazineCapacity>200</magazineCapacity>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/maxRange</xpath>
                    <value>
                        <maxRange>55</maxRange>
                    </value>
                </li>

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]/fireModes</xpath>
                    <value>
                        <fireModes>
                            <li>
                                <shotsPerBurst>1</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Single</label>
                                <texPath>UI/Gizmos/FireRate_Single</texPath>
                            </li>
                            <li>
                                <shotsPerBurst>5</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Burst</label>
                                <texPath>UI/Gizmos/FireRate_Burst</texPath>
                            </li>
                            <li>
                                <shotsPerBurst>10</shotsPerBurst>
                                <ticksBetweenShots>6</ticksBetweenShots>
                                <ticksBetweenBursts>60</ticksBetweenBursts>
                                <label>Auto</label>
                                <texPath>UI/Gizmos/FireRate_Auto</texPath>
                            </li>
                        </fireModes>
                    </value>
                </li>

                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/Vehicles.VehicleTurretDef[defName="P1000_Ball_Turret"]</xpath>
                    <value>
                        <li Class="Vehicles.CETurretDataDefModExtension">
                            <ammoSet>AmmoSet_762x51mmNATO</ammoSet>
                            <shotHeight>2.0</shotHeight>
                            <speed>156</speed>
                            <sway>0.96</sway>
                            <spread>0.04</spread>
                        </li>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_tank: engine explosion radius 40 → 3 -->
                <!-- CE increases explosion lethality; radius 3 prevents map-wiping -->
                <!-- while preserving the P1000's naval-ordnance flavor (larger than -->
                <!-- CE's standard VVE vehicle cap of 1) -->
                <!-- ==================== -->

                <li Class="PatchOperationReplace">
                    <xpath>Defs/Vehicles.VehicleDef[defName="P1000_tank"]/components/li[key="Engine"]/reactors/li[@Class="Vehicles.Reactor_Explosive"]/radius</xpath>
                    <value>
                        <radius>3</radius>
                    </value>
                </li>

                <!-- ==================== -->
                <!-- P1000_tank: ammo set hyperlinks for info card -->
                <!-- ==================== -->

                <li Class="PatchOperationAdd">
                    <xpath>Defs/Vehicles.VehicleDef[defName="P1000_tank"]</xpath>
                    <value>
                        <descriptionHyperlinks>
                            <CombatExtended.AmmoSetDef>AmmoSet_28cmSpgrShell</CombatExtended.AmmoSetDef>
                            <CombatExtended.AmmoSetDef>AmmoSet_75x350mmR</CombatExtended.AmmoSetDef>
                            <CombatExtended.AmmoSetDef>AmmoSet_20x128mmOerlikon</CombatExtended.AmmoSetDef>
                            <CombatExtended.AmmoSetDef>AmmoSet_762x51mmNATO</CombatExtended.AmmoSetDef>
                        </descriptionHyperlinks>
                    </value>
                </li>

            </operations>
        </match>
    </Operation>

</Patch>
