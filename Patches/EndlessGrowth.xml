<?xml version="1.0" encoding="utf-8"?>
<!--
    EndlessGrowth CE compatibility patch
    Extends ReloadSpeed and AimingDelayFactor valuesPerLevel from 21 to 101 entries
    to support skill levels beyond 20 added by EndlessGrowth (SlimeSenpai.EndlessGrowth).

    ReloadSpeed levels 21-100: f(L) = 1.50 + 0.50 * (1 - e^(-0.05 * (L - 20))), cap ~2.0
    AimingDelayFactor levels 21-100: g(L) = 0.75 - 0.25 * (1 - e^(-0.05 * (L - 20))), floor ~0.50
-->
