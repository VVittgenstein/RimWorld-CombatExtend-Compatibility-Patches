<?xml version="1.0" encoding="utf-8"?>
<Patch>

    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Phase Weaponry</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>

                <!-- === Phase Pistol === -->
                <li Class="CombatExtended.PatchOperationMakeGunCECompatible">
                    <defName>DV_Gun_PhasePistol</defName>
                    <statBases>
                        <Mass>2.5</Mass>
                        <Bulk>3.0</Bulk>
                        <ShotSpread>0.12</ShotSpread>
                        <SwayFactor>1.30</SwayFactor>
                        <SightsEfficiency>1.0</SightsEfficiency>
                        <RangedWeapon_Cooldown>0.36</RangedWeapon_Cooldown>
                    </statBases>
                    <Properties>
                        <verbClass>CombatExtended.Verb_ShootCE</verbClass>
                        <hasStandardCommand>true</hasStandardCommand>
                        <defaultProjectile>Bullet_PhaseEnergy</defaultProjectile>
                        <warmupTime>0.5</warmupTime>
                        <range>25</range>
                        <burstShotCount>1</burstShotCount>
                        <soundCast>Shot_ChargeRifle</soundCast>
                        <soundCastTail>GunTail_Medium</soundCastTail>
                        <muzzleFlashScale>9</muzzleFlashScale>
                        <recoilAmount>0.8</recoilAmount>
                    </Properties>
                    <AmmoUser>
                        <magazineSize>15</magazineSize>
                        <reloadTime>3</reloadTime>
                        <ammoSet>AmmoSet_PhaseEnergy</ammoSet>
                    </AmmoUser>
                    <FireModes>
                        <aiUseBurstMode>false</aiUseBurstMode>
                        <aiAimMode>AimedShot</aiAimMode>
                    </FireModes>
                </li>

                <!-- === Phase Rifle === -->
                <li Class="CombatExtended.PatchOperationMakeGunCECompatible">
                    <defName>DV_Gun_PhaseRifle</defName>
                    <statBases>
                        <Mass>4.0</Mass>
                        <Bulk>8.0</Bulk>
                        <ShotSpread>0.07</ShotSpread>
                        <SwayFactor>1.15</SwayFactor>
                        <SightsEfficiency>1.10</SightsEfficiency>
                        <RangedWeapon_Cooldown>0.36</RangedWeapon_Cooldown>
                    </statBases>
                    <Properties>
                        <verbClass>CombatExtended.Verb_ShootCE</verbClass>
                        <hasStandardCommand>true</hasStandardCommand>
                        <defaultProjectile>Bullet_PhaseEnergy</defaultProjectile>
                        <warmupTime>1.2</warmupTime>
                        <range>50</range>
                        <burstShotCount>3</burstShotCount>
                        <ticksBetweenBurstShots>8</ticksBetweenBurstShots>
                        <soundCast>Shot_ChargeRifle</soundCast>
                        <soundCastTail>GunTail_Medium</soundCastTail>
                        <muzzleFlashScale>9</muzzleFlashScale>
                        <recoilAmount>1.3</recoilAmount>
                    </Properties>
                    <AmmoUser>
                        <magazineSize>24</magazineSize>
                        <reloadTime>4</reloadTime>
                        <ammoSet>AmmoSet_PhaseEnergy</ammoSet>
                    </AmmoUser>
                    <FireModes>
                        <aiUseBurstMode>true</aiUseBurstMode>
                        <aimedBurstShotCount>3</aimedBurstShotCount>
                        <aiAimMode>AimedShot</aiAimMode>
                    </FireModes>
                </li>

                <!-- === Phase Precision Rifle === -->
                <li Class="CombatExtended.PatchOperationMakeGunCECompatible">
                    <defName>DV_Gun_PhasePrecisionRifle</defName>
                    <statBases>
                        <Mass>5.5</Mass>
                        <Bulk>11.0</Bulk>
                        <ShotSpread>0.02</ShotSpread>
                        <SwayFactor>0.90</SwayFactor>
                        <SightsEfficiency>1.30</SightsEfficiency>
                        <RangedWeapon_Cooldown>0.36</RangedWeapon_Cooldown>
                    </statBases>
                    <Properties>
                        <verbClass>CombatExtended.Verb_ShootCE</verbClass>
                        <hasStandardCommand>true</hasStandardCommand>
                        <defaultProjectile>Bullet_PhaseEnergy</defaultProjectile>
                        <warmupTime>1.6</warmupTime>
                        <range>60</range>
                        <burstShotCount>1</burstShotCount>
                        <soundCast>Shot_ChargeLance</soundCast>
                        <soundCastTail>GunTail_Heavy</soundCastTail>
                        <muzzleFlashScale>12</muzzleFlashScale>
                        <recoilAmount>0.9</recoilAmount>
                    </Properties>
                    <AmmoUser>
                        <magazineSize>8</magazineSize>
                        <reloadTime>4</reloadTime>
                        <ammoSet>AmmoSet_PhaseEnergy</ammoSet>
                    </AmmoUser>
                    <FireModes>
                        <aiUseBurstMode>false</aiUseBurstMode>
                        <aiAimMode>AimedShot</aiAimMode>
                    </FireModes>
                </li>

                <!-- === Ranger Helmet: add Bulk, WornBulk, StuffEffectMultiplierArmor === -->
                <li Class="PatchOperationAdd">
                    <xpath>Defs/ThingDef[@Name="DV_ApparelRangerHelmetBase"]/statBases</xpath>
                    <value>
                        <Bulk>3</Bulk>
                        <WornBulk>1</WornBulk>
                        <StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
                    </value>
                </li>

                <!-- === Ranger In Black: CE loadout extension === -->
                <li Class="PatchOperationAddModExtension">
                    <xpath>Defs/PawnKindDef[defName="DV_RangerInBlack"]</xpath>
                    <value>
                        <li Class="CombatExtended.LoadoutPropertiesExtension">
                            <primaryMagazineCount>
                                <min>5</min>
                                <max>8</max>
                            </primaryMagazineCount>
                        </li>
                    </value>
                </li>

            </operations>
        </match>
    </Operation>

</Patch>
