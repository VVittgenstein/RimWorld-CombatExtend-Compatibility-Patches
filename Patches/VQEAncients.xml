<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Vanilla Quests Expanded - Ancients</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>
                <!-- Fix Splicefiend duplicate ArmorDurability: remove the erroneous
                     Durability=500 entry, keeping only the intended Durability=1200 -->
                <li Class="PatchOperationRemove">
                    <xpath>Defs/ThingDef[defName="VQEA_Splicefiend"]/comps/li[@Class="CombatExtended.CompProperties_ArmorDurability"][Durability="500"]</xpath>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>
