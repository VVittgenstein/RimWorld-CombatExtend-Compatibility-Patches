<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- ==================== ThingCategory ==================== -->

    <ThingCategoryDef>
        <defName>AmmoPhaseEnergy</defName>
        <label>phase energy cells</label>
        <parent>AmmoAdvanced</parent>
    </ThingCategoryDef>

    <!-- ==================== AmmoSet ==================== -->

    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_PhaseEnergy</defName>
        <label>phase energy</label>
        <ammoTypes>
            <Ammo_PhaseEnergy>Bullet_PhaseEnergy</Ammo_PhaseEnergy>
            <Ammo_PhaseEnergy_Focused>Bullet_PhaseEnergy_Focused</Ammo_PhaseEnergy_Focused>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- ==================== Ammo ==================== -->

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
        <defName>Ammo_PhaseEnergy</defName>
        <label>phase energy cell</label>
        <description>A compact cell containing focused phase energy. Used in phase weaponry for clean, high-penetration cutting damage.</description>
        <statBases>
            <Mass>0.015</Mass>
            <Bulk>0.01</Bulk>
        </statBases>
        <thingCategories>
            <li>AmmoPhaseEnergy</li>
        </thingCategories>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting_TableMachining</li>
        </tradeTags>
        <graphicData>
            <texPath>Things/Ammo/Charged/SmallRegular</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <ammoClass>Charged</ammoClass>
    </ThingDef>

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
        <defName>Ammo_PhaseEnergy_Focused</defName>
        <label>phase energy cell (focused)</label>
        <description>A concentrated phase energy cell optimized for maximum armor penetration at the cost of raw damage output.</description>
        <statBases>
            <Mass>0.015</Mass>
            <Bulk>0.01</Bulk>
        </statBases>
        <thingCategories>
            <li>AmmoPhaseEnergy</li>
        </thingCategories>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting_TableMachining</li>
        </tradeTags>
        <graphicData>
            <texPath>Things/Ammo/Charged/SmallConc</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <ammoClass>ChargedAP</ammoClass>
    </ThingDef>

    <!-- ==================== Projectiles ==================== -->

    <ThingDef ParentName="BaseBulletCE">
        <defName>Bullet_PhaseEnergy</defName>
        <label>phase energy blade</label>
        <graphicData>
            <texPath>Things/Projectile/Charged/ChargeShot</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>DV_PhaseCut</damageDef>
            <speed>140</speed>
            <damageAmountBase>16</damageAmountBase>
            <armorPenetrationSharp>20</armorPenetrationSharp>
            <armorPenetrationBlunt>8</armorPenetrationBlunt>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseBulletCE">
        <defName>Bullet_PhaseEnergy_Focused</defName>
        <label>focused phase energy blade</label>
        <graphicData>
            <texPath>Things/Projectile/Charged/ChargeLanceShot</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>DV_PhaseCut</damageDef>
            <speed>140</speed>
            <damageAmountBase>12</damageAmountBase>
            <armorPenetrationSharp>35</armorPenetrationSharp>
            <armorPenetrationBlunt>6</armorPenetrationBlunt>
        </projectile>
    </ThingDef>

    <!-- ==================== Recipe ==================== -->

    <!-- ==================== Defensive DamageDef / HediffDef (FIX-07) ==================== -->
    <!-- Safety-net duplicate of Phase Weaponry's DV_PhaseCut + DV_PhaseCutHediff.
         Root cause of Phase Weaponry's loading failure is unknown; this ensures
         the projectiles above resolve their damageDef regardless. If Phase Weaponry
         loads correctly, RimWorld logs a harmless duplicate-defName info message. -->

    <DamageDef>
        <defName>DV_PhaseCut</defName>
        <label>cut</label>
        <workerClass>DamageWorker_AddInjury</workerClass>
        <externalViolence>true</externalViolence>
        <deathMessage>{0} has been cut to death.</deathMessage>
        <hediff>DV_PhaseCutHediff</hediff>
        <impactSoundType>Slice</impactSoundType>
        <armorCategory>Sharp</armorCategory>
        <overkillPctToDestroyPart>0.3~0.7</overkillPctToDestroyPart>
        <isRanged>true</isRanged>
        <makesAnimalsFlee>true</makesAnimalsFlee>
    </DamageDef>

    <HediffDef ParentName="InjuryBase">
        <defName>DV_PhaseCutHediff</defName>
        <label>cut</label>
        <labelNoun>a phase cut</labelNoun>
        <description>A phase blade cut.</description>
        <comps>
            <li Class="HediffCompProperties_TendDuration">
                <labelTendedWell>stitched</labelTendedWell>
                <labelTendedWellInner>tended</labelTendedWellInner>
                <labelSolidTendedWell>sutured</labelSolidTendedWell>
            </li>
            <li Class="HediffCompProperties_Infecter">
                <infectionChance>0.02</infectionChance>
            </li>
            <li Class="HediffCompProperties_GetsPermanent">
                <permanentLabel>phase cut scar</permanentLabel>
            </li>
        </comps>
        <injuryProps>
            <painPerSeverity>0.015</painPerSeverity>
            <averagePainPerSeverityPermanent>0.00420</averagePainPerSeverityPermanent>
            <bleedRate>0.03</bleedRate>
            <canMerge>true</canMerge>
            <destroyedLabel>Sliced off (phase)</destroyedLabel>
            <destroyedOutLabel>Sliced out (phase)</destroyedOutLabel>
        </injuryProps>
    </HediffDef>

    <RecipeDef ParentName="AmmoRecipeBase">
        <defName>MakeAmmo_PhaseEnergy</defName>
        <label>make phase energy cells x500</label>
        <description>Craft 500 phase energy cells.</description>
        <jobString>Making phase energy cells.</jobString>
        <workAmount>8000</workAmount>
        <targetCountAdjustment>500</targetCountAdjustment>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Plasteel</li>
                    </thingDefs>
                </filter>
                <count>10</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>8</count>
            </li>
            <li>
                <filter>
                    <thingDefs>
                        <li>ComponentIndustrial</li>
                    </thingDefs>
                </filter>
                <count>6</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Plasteel</li>
                <li>Steel</li>
                <li>ComponentIndustrial</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Ammo_PhaseEnergy>500</Ammo_PhaseEnergy>
        </products>
        <skillRequirements>
            <Crafting>7</Crafting>
        </skillRequirements>
        <researchPrerequisite>ChargedShot</researchPrerequisite>
    </RecipeDef>

</Defs>
