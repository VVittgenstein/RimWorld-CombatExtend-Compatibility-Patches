<?xml version="1.0" encoding="utf-8"?>
<Defs>

    <!-- ========== STC Energy Core Ammo Definitions ========== -->
    <!-- Shared energy core ammo for Tesla, Orbital, Rupture, Cluster Munition, and Drone turrets. -->
    <!-- These turrets keep their original projectiles; the AmmoSets map the new energy core to them. -->

    <!-- ==================== ThingCategoryDef ==================== -->

    <ThingCategoryDef>
        <defName>AmmoSTC_EnergyCore</defName>
        <label>STC energy cores</label>
        <parent>AmmoAdvanced</parent>
    </ThingCategoryDef>

    <!-- ==================== AmmoDef (shared physical item) ==================== -->

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SpacerSmallAmmoBase">
        <defName>Ammo_STC_EnergyCore</defName>
        <label>STC energy core</label>
        <description>A compact energy cell designed for STC turret systems. Compatible with Tesla coils, orbital beam emitters, rupture cannons, cluster munition launchers, and drone deployers.</description>
        <statBases>
            <Mass>1.0</Mass>
            <Bulk>1.5</Bulk>
        </statBases>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting_FabricationBench</li>
        </tradeTags>
        <thingCategories>
            <li>AmmoSTC_EnergyCore</li>
        </thingCategories>
        <graphicData>
            <texPath>Things/Ammo/Charged/Regular</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <ammoClass>Charged</ammoClass>
    </ThingDef>

    <!-- ==================== RecipeDef ==================== -->

    <RecipeDef ParentName="ChargeAmmoRecipeBase">
        <defName>MakeAmmo_STC_EnergyCore</defName>
        <label>make STC energy core x500</label>
        <description>Craft 500 STC energy cores.</description>
        <jobString>Making STC energy cores.</jobString>
        <ingredients>
            <li>
                <filter><thingDefs><li>Plasteel</li></thingDefs></filter>
                <count>12</count>
            </li>
            <li>
                <filter><thingDefs><li>Steel</li></thingDefs></filter>
                <count>6</count>
            </li>
            <li>
                <filter><thingDefs><li>ComponentIndustrial</li></thingDefs></filter>
                <count>8</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Plasteel</li>
                <li>Steel</li>
                <li>ComponentIndustrial</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Ammo_STC_EnergyCore>500</Ammo_STC_EnergyCore>
        </products>
        <workAmount>10000</workAmount>
    </RecipeDef>

    <!-- ==================== AmmoSetDefs ==================== -->
    <!-- Each AmmoSet maps the shared Ammo_STC_EnergyCore to the original STC projectile. -->

    <!-- Tesla Coil turret: VEF TeslaProjectile -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_STC_TeslaCharge</defName>
        <label>STC tesla charge</label>
        <ammoTypes>
            <Ammo_STC_EnergyCore>STC_Bullet_TeslaCoil</Ammo_STC_EnergyCore>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- Orbital Beam turret: VANILLA PRESERVED - ProjectileMultiple_Explosive -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_STC_OrbitalCharge</defName>
        <label>STC orbital charge</label>
        <ammoTypes>
            <Ammo_STC_EnergyCore>STC_bullet_OrbitalBeam</Ammo_STC_EnergyCore>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- Rupture turret: VANILLA PRESERVED - ProjectileMultiple_Explosive -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_STC_RuptureCharge</defName>
        <label>STC rupture charge</label>
        <ammoTypes>
            <Ammo_STC_EnergyCore>STC_bullet_Rupturer</Ammo_STC_EnergyCore>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- Cluster Munition turret: VANILLA PRESERVED - Projectile_ClusterMunition -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_STC_ClusterMunition</defName>
        <label>STC cluster munition</label>
        <ammoTypes>
            <Ammo_STC_EnergyCore>STC_FlyCracker_Projectile</Ammo_STC_EnergyCore>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- Drone turret: VANILLA PRESERVED - Projectile_Explosive with homing -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_STC_Drone</defName>
        <label>STC drone charge</label>
        <ammoTypes>
            <Ammo_STC_EnergyCore>STC_Bullet_Drone</Ammo_STC_EnergyCore>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

</Defs>
